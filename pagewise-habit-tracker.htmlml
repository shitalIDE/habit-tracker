<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>PageWise Wellness Tracker</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --bg: #f7f6f2; --surface: #ffffff; --surface2: #f0ede6;
    --border: rgba(0,0,0,0.1); --border2: rgba(0,0,0,0.18);
    --text: #1a1a18; --text2: #6b6b67; --text3: #9b9b96;
    --green: #639922; --green-light: #eaf3de;
    --teal: #1D9E75; --blue: #378ADD; --amber: #BA7517;
    --amber-light: #faeeda; --red: #E24B4A; --purple: #7F77DD;
    --radius: 10px; --radius-lg: 14px;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1a18; --surface: #242422; --surface2: #2e2e2b;
      --border: rgba(255,255,255,0.1); --border2: rgba(255,255,255,0.18);
      --text: #f0ede6; --text2: #a0a09a; --text3: #666660;
      --green-light: #1a2e0a; --amber-light: #2e1f06;
    }
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); font-size: 14px; line-height: 1.5; }
  .app { max-width: 920px; margin: 0 auto; padding: 2rem 1rem; }

  /* SETUP SCREEN */
  .setup-screen { min-height: 100vh; display: flex; align-items: center; justify-content: center; }
  .setup-card { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 2.5rem; max-width: 480px; width: 100%; }
  .setup-card h2 { font-size: 20px; font-weight: 500; margin-bottom: 6px; }
  .setup-card p { font-size: 13px; color: var(--text2); margin-bottom: 1.5rem; line-height: 1.6; }
  .setup-label { font-size: 12px; font-weight: 500; color: var(--text2); margin-bottom: 6px; display: block; }
  .setup-input { width: 100%; padding: 10px 12px; border: 0.5px solid var(--border2); border-radius: var(--radius); font-size: 13px; background: var(--surface); color: var(--text); outline: none; font-family: monospace; }
  .setup-input:focus { border-color: var(--green); }
  .setup-btn { width: 100%; margin-top: 1rem; padding: 10px; background: var(--green); color: #fff; border: none; border-radius: var(--radius); font-size: 14px; font-weight: 500; cursor: pointer; }
  .setup-btn:hover { opacity: 0.9; }
  .setup-note { font-size: 11px; color: var(--text3); margin-top: 10px; text-align: center; }

  /* MAIN APP */
  .main-app { display: none; }
  .header { margin-bottom: 1.75rem; display: flex; justify-content: space-between; align-items: flex-start; }
  .header h1 { font-size: 22px; font-weight: 500; }
  .header p { font-size: 13px; color: var(--text2); margin-top: 2px; }
  .goal-pill { display: inline-block; margin-top: 8px; background: var(--green-light); color: var(--green); font-size: 12px; font-weight: 500; padding: 3px 10px; border-radius: 20px; }
  .notion-pill { display: inline-block; margin-top: 8px; margin-left: 8px; font-size: 12px; padding: 3px 10px; border-radius: 20px; background: var(--surface2); color: var(--text2); }
  .notion-pill.synced { color: var(--green); }
  .notion-pill.error { color: var(--red); }
  .reset-btn { font-size: 11px; color: var(--text3); background: none; border: 0.5px solid var(--border2); border-radius: 20px; padding: 4px 10px; cursor: pointer; }
  .reset-btn:hover { color: var(--red); border-color: var(--red); }

  .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-bottom: 1.5rem; }
  .stat-card { background: var(--surface2); border-radius: var(--radius); padding: 14px; text-align: center; }
  .stat-label { font-size: 11px; color: var(--text3); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; }
  .stat-val { font-size: 24px; font-weight: 500; }
  .stat-val.green { color: var(--green); }
  .stat-val.red { color: var(--red); }
  .stat-val.amber { color: var(--amber); }

  .month-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .tab { padding: 5px 14px; border: 0.5px solid var(--border2); border-radius: 20px; font-size: 12px; cursor: pointer; background: var(--surface); color: var(--text2); white-space: nowrap; transition: all .15s; }
  .tab:hover { background: var(--surface2); }
  .tab.active { background: var(--green); color: #fff; border-color: var(--green); font-weight: 500; }

  .main-grid { display: grid; grid-template-columns: 1fr 270px; gap: 1rem; }
  .card { background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 1.1rem 1.25rem; }
  .section-title { font-size: 11px; font-weight: 500; color: var(--text3); text-transform: uppercase; letter-spacing: .06em; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center; }
  .target-badge { font-size: 10px; background: var(--green-light); color: var(--green); padding: 2px 7px; border-radius: 10px; font-weight: 500; text-transform: none; letter-spacing: 0; }

  .log-header { display: grid; grid-template-columns: 80px 90px 1fr 1fr 1fr 1fr 44px; gap: 6px; padding-bottom: 8px; border-bottom: 0.5px solid var(--border); margin-bottom: 4px; font-size: 11px; color: var(--text3); text-align: center; }
  .log-header span:first-child { text-align: left; }
  .day-row { display: grid; grid-template-columns: 80px 90px 1fr 1fr 1fr 1fr 44px; gap: 6px; align-items: center; padding: 7px 0; border-bottom: 0.5px solid var(--border); }
  .day-row:last-child { border-bottom: none; }
  .day-name { font-size: 12px; color: var(--text2); }
  .num-wrap { display: flex; justify-content: center; }
  .num-in { width: 62px; padding: 4px 6px; border: 0.5px solid var(--border2); border-radius: 8px; font-size: 13px; background: var(--surface); color: var(--text); text-align: center; outline: none; }
  .num-in:focus { border-color: var(--green); }
  .cb-wrap { display: flex; justify-content: center; }
  .cb { width: 18px; height: 18px; accent-color: var(--green); cursor: pointer; }
  .goal-icon { text-align: center; font-size: 15px; }
  .sync-icon { text-align: center; font-size: 13px; }

  .side-col { display: flex; flex-direction: column; gap: 1rem; }
  .donut-wrap { position: relative; width: 100%; height: 190px; }
  .legend { display: flex; flex-direction: column; gap: 7px; margin-top: 10px; }
  .legend-row { display: flex; align-items: center; justify-content: space-between; font-size: 12px; color: var(--text2); }
  .legend-dot { width: 9px; height: 9px; border-radius: 2px; display: inline-block; margin-right: 6px; }

  .streak-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 4px; }
  .streak-cell { height: 22px; border-radius: 4px; }
  .streak-key { display: flex; gap: 12px; margin-top: 8px; }
  .streak-key span { font-size: 11px; color: var(--text3); display: flex; align-items: center; gap: 4px; }
  .streak-key .dot { width: 9px; height: 9px; border-radius: 2px; }

  .monthly-summary { margin-top: 1rem; background: var(--surface); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 1.1rem 1.25rem; }
  .summary-grid { display: grid; grid-template-columns: repeat(7,1fr); gap: 8px; margin-top: 10px; }
  .summary-month { text-align: center; }
  .summary-month-name { font-size: 10px; color: var(--text3); margin-bottom: 4px; }
  .summary-bar-wrap { height: 60px; display: flex; align-items: flex-end; justify-content: center; }
  .summary-bar { width: 24px; border-radius: 4px 4px 0 0; background: var(--green); min-height: 3px; }
  .summary-pct { font-size: 10px; color: var(--text2); margin-top: 3px; }

  .toast { position: fixed; bottom: 1.5rem; right: 1.5rem; font-size: 12px; padding: 8px 16px; border-radius: 20px; opacity: 0; transition: opacity .3s; pointer-events: none; z-index: 999; font-weight: 500; }
  .toast.show { opacity: 1; }
  .toast.success { background: var(--green); color: #fff; }
  .toast.fail { background: var(--red); color: #fff; }
  .toast.syncing { background: var(--surface); color: var(--text2); border: 0.5px solid var(--border2); }

  @media (max-width: 640px) {
    .main-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2,1fr); }
    .summary-grid { grid-template-columns: repeat(4,1fr); }
  }
</style>
</head>
<body>

<!-- SETUP SCREEN -->
<div class="setup-screen" id="setup-screen">
  <div class="setup-card">
    <h2>🌞 PageWise Wellness Tracker</h2>
    <p>Connect your Notion workspace to sync your daily habits. Your token is stored only in your browser — never shared or uploaded anywhere.</p>
    <label class="setup-label">Notion Integration Token</label>
    <input class="setup-input" type="password" id="token-input" placeholder="ntn_..." />
    <label class="setup-label" style="margin-top:1rem">Notion Database ID</label>
    <input class="setup-input" type="text" id="db-input" placeholder="ae889a760584499590f1..." />
    <button class="setup-btn" onclick="saveSetup()">Connect to Notion →</button>
    <p class="setup-note">Token and Database ID are saved in your browser only. Never in the code.</p>
  </div>
</div>

<!-- MAIN APP -->
<div class="main-app" id="main-app">
<div class="app">

  <div class="header">
    <div>
      <h1>🌞 Wellness Tracker</h1>
      <p>Suryanamaskar · Stretch · Meditation · Reading</p>
      <span class="goal-pill">🎯 108 Surya × 5 days/week by Dec 2026</span>
      <span class="notion-pill" id="notion-status">⚡ Connecting...</span>
    </div>
    <div style="display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end;">
      <button class="reset-btn" onclick="exportBackup()">⬇️ Export backup</button>
      <button class="reset-btn" onclick="document.getElementById('restore-input').click()">⬆️ Restore backup</button>
      <input type="file" id="restore-input" accept="application/json" style="display:none" onchange="restoreBackup(event)" />
      <button class="reset-btn" onclick="resetSetup()">Reset token</button>
    </div>
  </div>

  <div class="stats-grid">
    <div class="stat-card"><div class="stat-label">Active habits</div><div class="stat-val green">4</div></div>
    <div class="stat-card"><div class="stat-label">Completion rate</div><div class="stat-val" id="s-rate">0%</div></div>
    <div class="stat-card"><div class="stat-label">Current streak</div><div class="stat-val" id="s-streak">0 days</div></div>
    <div class="stat-card"><div class="stat-label">Longest streak</div><div class="stat-val green" id="s-best">0 days</div></div>
  </div>

  <div class="month-tabs" id="month-tabs"></div>

  <div class="main-grid">
    <div class="card">
      <div class="section-title">
        <span>Daily log — <span id="active-month-label"></span></span>
        <span class="target-badge" id="target-badge"></span>
      </div>
      <div class="log-header">
        <span>Date</span><span>🌞 Surya</span><span>🤸 Stretch</span><span>🧘 Meditate</span><span>📖 Reading</span><span>Goal</span><span>Sync</span>
      </div>
      <div id="day-rows"></div>
    </div>

    <div class="side-col">
      <div class="card">
        <div class="section-title">Completion by habit</div>
        <div class="donut-wrap"><canvas id="donut-chart"></canvas></div>
        <div class="legend" id="donut-legend"></div>
      </div>
      <div class="card">
        <div class="section-title">Habit streak</div>
        <div class="streak-grid" id="streak-grid"></div>
        <div class="streak-key">
          <span><span class="dot" style="background:#639922"></span>All done</span>
          <span><span class="dot" style="background:#EF9F27"></span>Partial</span>
          <span><span class="dot" style="background:var(--surface2)"></span>Future</span>
        </div>
      </div>
    </div>
  </div>

  <div class="monthly-summary">
    <div class="section-title">Monthly overview</div>
    <div class="summary-grid" id="summary-grid"></div>
  </div>

</div>
</div>

<div class="toast" id="toast"></div>

<script>
const MONTHS = [
  {label:'June 2026',     short:'Jun', target:50,  days:['Jun 23','Jun 24','Jun 25','Jun 26','Jun 27','Jun 30']},
  {label:'July 2026',     short:'Jul', target:60,  days:['Jul 1','Jul 2','Jul 3','Jul 4','Jul 7','Jul 8','Jul 9','Jul 10','Jul 11','Jul 14','Jul 15','Jul 16','Jul 17','Jul 18','Jul 21','Jul 22','Jul 23','Jul 24','Jul 25','Jul 28','Jul 29','Jul 30','Jul 31']},
  {label:'August 2026',   short:'Aug', target:70,  days:['Aug 1','Aug 4','Aug 5','Aug 6','Aug 7','Aug 8','Aug 11','Aug 12','Aug 13','Aug 14','Aug 15','Aug 18','Aug 19','Aug 20','Aug 21','Aug 22','Aug 25','Aug 26','Aug 27','Aug 28','Aug 29']},
  {label:'September 2026',short:'Sep', target:90,  days:['Sep 1','Sep 2','Sep 3','Sep 4','Sep 5','Sep 8','Sep 9','Sep 10','Sep 11','Sep 12','Sep 15','Sep 16','Sep 17','Sep 18','Sep 19','Sep 22','Sep 23','Sep 24','Sep 25','Sep 26','Sep 29','Sep 30']},
  {label:'October 2026',  short:'Oct', target:100, days:['Oct 1','Oct 2','Oct 3','Oct 6','Oct 7','Oct 8','Oct 9','Oct 10','Oct 13','Oct 14','Oct 15','Oct 16','Oct 17','Oct 20','Oct 21','Oct 22','Oct 23','Oct 24','Oct 27','Oct 28','Oct 29','Oct 30','Oct 31']},
  {label:'November 2026', short:'Nov', target:108, days:['Nov 3','Nov 4','Nov 5','Nov 6','Nov 7','Nov 10','Nov 11','Nov 12','Nov 13','Nov 14','Nov 17','Nov 18','Nov 19','Nov 20','Nov 21','Nov 24','Nov 25','Nov 26','Nov 27','Nov 28']},
  {label:'December 2026', short:'Dec', target:108, days:['Dec 1','Dec 2','Dec 3','Dec 4','Dec 5','Dec 8','Dec 9','Dec 10','Dec 11','Dec 12','Dec 15','Dec 16','Dec 17','Dec 18','Dec 19']}
];

const STORAGE_KEY = 'pagewise_v3';
const CONFIG_KEY  = 'pagewise_config';

function toISO(dayLabel, mLabel) {
  const months = {Jan:'01',Feb:'02',Mar:'03',Apr:'04',May:'05',Jun:'06',Jul:'07',Aug:'08',Sep:'09',Oct:'10',Nov:'11',Dec:'12'};
  const [mon, num] = dayLabel.split(' ');
  const year = mLabel.split(' ')[1];
  return `${year}-${months[mon]}-${num.padStart(2,'0')}`;
}

function loadLocal() {
  try { const r = localStorage.getItem(STORAGE_KEY); if (r) return JSON.parse(r); } catch(e){}
  const d = {};
  MONTHS.forEach(m => { d[m.label] = {}; m.days.forEach(day => { d[m.label][day] = {surya:'',stretch:false,meditation:false,reading:false,pageId:null,synced:false}; }); });
  return d;
}

let data = loadLocal();
let activeMonth = 0;
let donutChart = null;
let notionReady = false;
let NOTION_TOKEN = '';
let DATABASE_ID  = '';

function saveLocal() { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }

// ── BACKUP / RESTORE ──────────────────────────────────────────────────────
// Note: only the habit log (STORAGE_KEY) is exported — never the Notion token (CONFIG_KEY).
window.exportBackup = function() {
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  const stamp = new Date().toISOString().slice(0, 10);
  a.href = url;
  a.download = `pagewise-wellness-backup-${stamp}.json`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
  showToast('Backup downloaded ✅', 'success');
};

window.restoreBackup = function(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const restored = JSON.parse(e.target.result);
      if (!confirm('This will overwrite your current data with the backup file. Continue?')) { event.target.value = ''; return; }
      data = restored;
      saveLocal();
      render();
      showToast('Backup restored ✅', 'success');
    } catch (err) {
      showToast('❌ Could not read backup file', 'fail');
    }
    event.target.value = '';
  };
  reader.readAsText(file);
};

// ── SETUP ──────────────────────────────────────────────────────────────────
window.saveSetup = function() {
  const token = document.getElementById('token-input').value.trim();
  const db    = document.getElementById('db-input').value.trim().replace(/-/g,'');
  if (!token.startsWith('ntn_') && !token.startsWith('secret_')) { alert('Token should start with ntn_ or secret_'); return; }
  if (db.length < 20) { alert('Please enter your Database ID'); return; }
  localStorage.setItem(CONFIG_KEY, JSON.stringify({token, db}));
  NOTION_TOKEN = token;
  DATABASE_ID  = db;
  showApp();
};

window.resetSetup = function() {
  if (!confirm('Reset Notion connection? Your logged data stays safe.')) return;
  localStorage.removeItem(CONFIG_KEY);
  document.getElementById('setup-screen').style.display = 'flex';
  document.getElementById('main-app').style.display = 'none';
};

function showApp() {
  document.getElementById('setup-screen').style.display = 'none';
  document.getElementById('main-app').style.display = 'block';
  render();
  loadFromNotion();
}

function checkConfig() {
  try {
    const c = localStorage.getItem(CONFIG_KEY);
    if (c) {
      const {token, db} = JSON.parse(c);
      NOTION_TOKEN = token; DATABASE_ID = db;
      showApp(); return;
    }
  } catch(e){}
  document.getElementById('setup-screen').style.display = 'flex';
}

// ── NOTION API ─────────────────────────────────────────────────────────────
async function notionRequest(path, method='GET', body=null) {
  const url = `https://corsproxy.io/?url=${encodeURIComponent('https://api.notion.com/v1' + path)}`;
  const opts = {
    method,
    headers: { 'Authorization': `Bearer ${NOTION_TOKEN}`, 'Notion-Version': '2022-06-28', 'Content-Type': 'application/json' }
  };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(url, opts);
  if (!res.ok) throw new Error(`${res.status}`);
  return res.json();
}

async function loadFromNotion() {
  showToast('Loading from Notion...', 'syncing');
  try {
    const res = await notionRequest(`/databases/${DATABASE_ID}/query`, 'POST', { page_size: 200 });
    res.results.forEach(page => {
      const props = page.properties;
      const dateVal = props['Date']?.date?.start;
      if (!dateVal) return;
      MONTHS.forEach(m => {
        m.days.forEach(day => {
          if (toISO(day, m.label) === dateVal) {
            const e = data[m.label][day];
            e.pageId     = page.id;
            e.surya      = props['Suryanamaskar Actual']?.number ?? '';
            e.stretch    = props['✅ Stretch Done']?.checkbox ?? false;
            e.meditation = props['🧘 Meditation Done']?.checkbox ?? false;
            e.reading    = props['📖 Reading Done']?.checkbox ?? false;
            e.synced     = true;
          }
        });
      });
    });
    saveLocal(); notionReady = true;
    setNotionStatus('synced', '✅ Notion connected');
    showToast('Loaded from Notion!', 'success');
    render();
  } catch(e) {
    setNotionStatus('error', '❌ Notion error — check token');
    showToast('Could not reach Notion. Data saved locally.', 'fail');
    render();
  }
}

async function syncToNotion(mLabel, day) {
  const m = MONTHS.find(x => x.label === mLabel);
  const e = data[mLabel][day];
  const properties = {
    'Name':                 { title: [{ text: { content: `🌞 ${day}` } }] },
    'Date':                 { date: { start: toISO(day, mLabel) } },
    'Month':                { select: { name: mLabel } },
    'Suryanamaskar Target': { number: m.target },
    'Suryanamaskar Actual': { number: e.surya !== '' ? Number(e.surya) : null },
    '✅ Stretch Done':      { checkbox: !!e.stretch },
    '🧘 Meditation Done':   { checkbox: !!e.meditation },
    '📖 Reading Done':      { checkbox: !!e.reading },
    '🎯 Goal Met?':         { checkbox: goalMet(e, m.target) }
  };
  try {
    if (e.pageId) {
      await notionRequest(`/pages/${e.pageId}`, 'PATCH', { properties });
    } else {
      const res = await notionRequest('/pages', 'POST', { parent: { database_id: DATABASE_ID }, properties });
      data[mLabel][day].pageId = res.id;
    }
    data[mLabel][day].synced = true; saveLocal(); return true;
  } catch(err) {
    data[mLabel][day].synced = false; saveLocal(); return false;
  }
}

// ── HELPERS ────────────────────────────────────────────────────────────────
function goalMet(e, t) { return Number(e.surya) >= t && e.stretch && e.meditation && e.reading; }
function anyDone(e)    { return e.surya || e.stretch || e.meditation || e.reading; }
function setNotionStatus(type, text) { const el = document.getElementById('notion-status'); el.textContent = text; el.className = `notion-pill ${type}`; }

let toastTimer;
function showToast(msg, type='success') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = `toast show ${type}`;
  clearTimeout(toastTimer); toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
}

function computeStats(mLabel) {
  const m = MONTHS.find(x => x.label === mLabel);
  const days = Object.keys(data[mLabel]); const total = days.length;
  if (!total) return {rate:0,surya:0,stretch:0,med:0,read:0,total:0};
  let surya=0,stretch=0,med=0,read=0;
  days.forEach(d => { const e=data[mLabel][d]; if(Number(e.surya)>=m.target)surya++; if(e.stretch)stretch++; if(e.meditation)med++; if(e.reading)read++; });
  return {rate:Math.round(((surya+stretch+med+read)/(total*4))*100),surya,stretch,med,read,total};
}

function computeStreaks() {
  let running=0,best=0;
  MONTHS.forEach(m => { m.days.forEach(d => { const e=data[m.label][d]; if(goalMet(e,m.target)){running++;best=Math.max(best,running);}else running=0; }); });
  return {cur:running,best};
}

// ── RENDER ─────────────────────────────────────────────────────────────────
function renderTabs() {
  document.getElementById('month-tabs').innerHTML = MONTHS.map((m,i) =>
    `<button class="tab${i===activeMonth?' active':''}" onclick="switchMonth(${i})">${m.short} '26</button>`).join('');
}

function renderRows() {
  const m = MONTHS[activeMonth];
  document.getElementById('active-month-label').textContent = m.label;
  document.getElementById('target-badge').textContent = `Target: ${m.target} rounds`;
  document.getElementById('day-rows').innerHTML = m.days.map(d => {
    const e = data[m.label][d];
    const met = goalMet(e,m.target), partial = !met && anyDone(e);
    const goalIcon = met ? `<span style="color:var(--green)">✓</span>` : partial ? `<span style="color:var(--amber)">~</span>` : `<span style="color:var(--border2)">—</span>`;
    const syncIcon = e.synced ? `<span title="Synced">✅</span>` : anyDone(e) ? `<span title="Pending" style="color:var(--amber)">⏳</span>` : `<span style="color:var(--border2)">○</span>`;
    return `<div class="day-row">
      <span class="day-name">${d}</span>
      <div class="num-wrap"><input class="num-in" type="number" min="0" max="200" value="${e.surya}" placeholder="${m.target}" onchange="handleChange('${m.label}','${d}','surya',this.value)"/></div>
      <div class="cb-wrap"><input type="checkbox" class="cb" ${e.stretch?'checked':''} onchange="handleChange('${m.label}','${d}','stretch',this.checked)"/></div>
      <div class="cb-wrap"><input type="checkbox" class="cb" ${e.meditation?'checked':''} onchange="handleChange('${m.label}','${d}','meditation',this.checked)"/></div>
      <div class="cb-wrap"><input type="checkbox" class="cb" ${e.reading?'checked':''} onchange="handleChange('${m.label}','${d}','reading',this.checked)"/></div>
      <div class="goal-icon">${goalIcon}</div>
      <div class="sync-icon">${syncIcon}</div>
    </div>`;
  }).join('');
}

function renderDonut() {
  const s = computeStats(MONTHS[activeMonth].label); const t = s.total||1;
  const missed = Math.max((t-s.surya)+(t-s.stretch)+(t-s.med)+(t-s.read),0);
  if (donutChart) { donutChart.destroy(); donutChart=null; }
  donutChart = new Chart(document.getElementById('donut-chart'), {
    type:'doughnut',
    data:{ labels:['Suryanamaskar','Stretch','Meditation','Reading','Missed'], datasets:[{data:[s.surya,s.stretch,s.med,s.read,missed],backgroundColor:['#639922','#1D9E75','#7F77DD','#378ADD','#D3D1C7'],borderWidth:0,hoverOffset:4}] },
    options:{ responsive:true,maintainAspectRatio:false,cutout:'65%',plugins:{ legend:{display:false}, tooltip:{callbacks:{label:ctx=>` ${ctx.label}: ${ctx.raw}/${t} days`}} } }
  });
  document.getElementById('donut-legend').innerHTML = [
    ['#639922','Suryanamaskar',s.surya],['#1D9E75','Stretch',s.stretch],['#7F77DD','Meditation',s.med],['#378ADD','Reading 30min',s.read]
  ].map(([c,n,v])=>`<div class="legend-row"><span><span class="legend-dot" style="background:${c}"></span>${n}</span><span style="font-weight:500;color:var(--text)">${v}/${t}</span></div>`).join('');
}

function renderStreakGrid() {
  const m = MONTHS[activeMonth];
  document.getElementById('streak-grid').innerHTML = m.days.map(d => {
    const e=data[m.label][d]; const bg=goalMet(e,m.target)?'#639922':anyDone(e)?'#EF9F27':'var(--surface2)';
    return `<div class="streak-cell" style="background:${bg}" title="${d}"></div>`;
  }).join('');
}

function renderSummary() {
  document.getElementById('summary-grid').innerHTML = MONTHS.map(m => {
    const s=computeStats(m.label); const h=s.total?Math.round((s.rate/100)*56):3;
    return `<div class="summary-month"><div class="summary-month-name">${m.short}</div><div class="summary-bar-wrap"><div class="summary-bar" style="height:${h}px"></div></div><div class="summary-pct">${s.rate}%</div></div>`;
  }).join('');
}

function renderStats() {
  const s=computeStats(MONTHS[activeMonth].label); const g=computeStreaks();
  const rEl=document.getElementById('s-rate'); rEl.textContent=s.rate+'%'; rEl.className='stat-val '+(s.rate>=75?'green':s.rate>=40?'amber':'red');
  const sEl=document.getElementById('s-streak'); sEl.textContent=g.cur+' days'; sEl.className='stat-val '+(g.cur>=5?'green':g.cur>0?'amber':'red');
  document.getElementById('s-best').textContent=g.best+' days';
}

function render() { renderTabs(); renderRows(); renderDonut(); renderStreakGrid(); renderStats(); renderSummary(); }

window.switchMonth = function(i) { activeMonth=i; render(); };

window.handleChange = async function(mLabel, day, field, val) {
  if(field==='surya') data[mLabel][day].surya=val; else data[mLabel][day][field]=val;
  data[mLabel][day].synced=false; saveLocal();
  renderDonut(); renderStreakGrid(); renderStats(); renderSummary(); renderRows();
  if(notionReady) {
    showToast('Syncing to Notion...','syncing');
    const ok = await syncToNotion(mLabel,day);
    showToast(ok?'✅ Saved to Notion!':'❌ Sync failed — saved locally', ok?'success':'fail');
    renderRows();
  }
};

checkConfig();
</script>
</body>
</html>
